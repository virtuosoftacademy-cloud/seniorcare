# ----------------------------------------------------------------------------
# SMTP credentials for Nodemailer
# ----------------------------------------------------------------------------
# Examples:
#   - Gmail (with App Password):  SMTP_HOST=smtp.gmail.com   SMTP_PORT=587
#   - Microsoft 365:              SMTP_HOST=smtp.office365.com SMTP_PORT=587
#   - SendGrid:                   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   - Mailgun:                    SMTP_HOST=smtp.mailgun.org   SMTP_PORT=587
#   - Resend (SMTP):              SMTP_HOST=smtp.resend.com    SMTP_PORT=465
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Address that appears in the "From" header.
# Must be a domain you're allowed to send from.
MAIL_FROM="Ardell Living <no-reply@ardellliving.co.uk>"

# Where contact form enquiries should be delivered.
CONTACT_INBOX=info@ardellliving.co.uk

# Used by the server action to call its own /api/contact route.
# In production this should be your deployed URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
